---
import '../styles/variables.css';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { getLangFromUrl } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: 'es' | 'en' | 'fr';
}

const { title, description, image, lang: langProp } = Astro.props;
const lang = langProp ?? getLangFromUrl(Astro.url);

const defaultTitle = 'cadiz.is';
const defaultDescription = {
  es: 'Historias, guías y planes sobre Cádiz para locales y viajeros.',
  en: 'Stories, guides and plans about Cádiz for locals and visitors.',
  fr: 'Histoires, guides et plans sur Cadix pour locaux et voyageurs.',
}[lang];

const pageTitle = title ? `${title} — cadiz.is` : defaultTitle;
const pageDesc = description ?? defaultDescription;
const siteUrl = 'https://cadiz.is';
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/images/og-default.webp`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="cadiz.is" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Alternate languages -->
    <link rel="alternate" hreflang="es" href={Astro.url.href.replace(`/${lang}/`, '/es/')} />
    <link rel="alternate" hreflang="en" href={Astro.url.href.replace(`/${lang}/`, '/en/')} />
    <link rel="alternate" hreflang="fr" href={Astro.url.href.replace(`/${lang}/`, '/fr/')} />
  </head>
  <body>
    <Navbar lang={lang} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
