---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeaturedArticle from '../../components/articles/FeaturedArticle.astro';
import ArticleGrid from '../../components/articles/ArticleGrid.astro';
import { t } from '../../i18n/index';
import { getCollection } from 'astro:content';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = await getCollection('articles', (entry) => entry.id.startsWith('en/'));
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredArticle = sorted[0];
const restArticles = sorted.slice(1, 6);
---

<BaseLayout lang={lang} title={t(lang, 'meta.site_name')} description={t(lang, 'meta.site_description')}>
  <section class="home-hero">
    <h1 class="home-hero__title" id="hero-title">
      Cádiz<span>.is</span>{' '}
      <span class="word-slider-container">
        <span class="word-slider-item anim-0" id="hero-word" style="color: #ef4444">alive</span>
      </span>
    </h1>
    <a class="home-hero__quiz-btn" href={`${base}/${lang}/quiz`}>
      🐟 <span>{t(lang, 'home.quiz')}</span> {t(lang, 'home.quiz_action')}
    </a>
    <div class="home-hero__subtitle">{t(lang, 'home.subtitle')}</div>
    <div class="home-hero__desc">{t(lang, 'home.desc')}</div>
  </section>

  <section class="home-intro">
    <div class="home-intro__inner">
      <p class="home-intro__label">What is cadiz.is?</p>
      <p class="home-intro__text">
        Cádiz is the oldest city in the Western world and one of the most alive on the planet.
        <em>cadiz.is</em> was born to tell its story without filters: its festivals, its food,
        its beaches, its history and its soul. A portal made by and for those who love this city,
        in Spanish, English and French.
      </p>
      <div class="home-intro__pillars">
        <a href={`${base}/en/fiestas`} class="home-intro__pillar"><span>Festivals</span></a>
        <a href={`${base}/en/turismo`} class="home-intro__pillar"><span>Tourism</span></a>
        <a href={`${base}/en/gastronomia`} class="home-intro__pillar"><span>Food</span></a>
        <a href={`${base}/en/cultura`} class="home-intro__pillar"><span>Culture</span></a>
      </div>
    </div>
  </section>

  <div class="container section">
    <div class="home-articles__header">
      <h2 class="home-articles__title">Latest</h2>
      <a href={`${base}/en/articles`} class="home-articles__all">See all articles →</a>
    </div>
    {featuredArticle && <FeaturedArticle article={featuredArticle} lang={lang} />}
    {restArticles.length > 0 && <ArticleGrid articles={restArticles} lang={lang} />}
  </div>
</BaseLayout>

<script>
  const words = ['alive', 'joyful', 'salty', 'bright', 'eternal', 'magical', 'infinite'];
  const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#3b82f6', '#6366f1', '#a855f7'];
  const anims = ['anim-0', 'anim-1', 'anim-2', 'anim-3', 'anim-4', 'anim-5', 'anim-6'];
  let idx = 0;
  const el = document.getElementById('hero-word');
  if (el) {
    setInterval(() => {
      idx = (idx + 1) % words.length;
      el.textContent = words[idx];
      el.style.color = colors[idx];
      el.className = `word-slider-item ${anims[idx]}`;
    }, 2000);
  }
</script>
