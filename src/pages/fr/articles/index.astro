---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleGrid from '../../../components/articles/ArticleGrid.astro';
import { getCollection } from 'astro:content';

const lang = 'fr';
const allArticles = await getCollection('articles', (entry) => entry.id.startsWith('fr/'));
const articles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
---

<BaseLayout lang={lang} title="Tous les articles — cadiz.is" description="Tous les articles sur Cadix : fêtes, tourisme, gastronomie et culture.">
  <div class="container section">
    <div class="page-hero">
      <h1 class="page-hero__title">Tous les articles</h1>
      <p class="page-hero__desc">Fêtes, tourisme, gastronomie et culture de Cadix.</p>
    </div>
    <ArticleGrid articles={articles} lang={lang} />
  </div>
</BaseLayout>
