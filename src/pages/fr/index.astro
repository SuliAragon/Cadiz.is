---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleGrid from '../../components/articles/ArticleGrid.astro';
import { t } from '../../i18n/index';
import { getCollection } from 'astro:content';

const lang = 'fr';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = await getCollection('articles', (entry) => entry.id.startsWith('fr/'));
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featured = sorted.slice(0, 6);
---

<BaseLayout lang={lang} title={t(lang, 'meta.site_name')} description={t(lang, 'meta.site_description')}>
  <section class="home-hero">
    <h1 class="home-hero__title">
      Cádiz<span>.is</span>{' '}
      <span class="word-slider-container">
        <span class="word-slider-item anim-0" id="hero-word" style="color: #ef4444">vivante</span>
      </span>
    </h1>
    <a class="home-hero__quiz-btn" href={`${base}/${lang}/quiz`}>
      🐟 <span>{t(lang, 'home.quiz')}</span> {t(lang, 'home.quiz_action')}
    </a>
    <div class="home-hero__subtitle">{t(lang, 'home.subtitle')}</div>
    <div class="home-hero__desc">{t(lang, 'home.desc')}</div>
  </section>

  <!-- INTRO -->
  <section class="home-intro">
    <div class="home-intro__inner">
      <p class="home-intro__label">Qu'est-ce que cadiz.is ?</p>
      <p class="home-intro__text">
        Cadix est la plus ancienne ville d'Occident et l'une des plus vivantes de la planète.
        <em>cadiz.is</em> est né pour la raconter sans filtre : ses fêtes, sa gastronomie,
        ses plages, son histoire et son âme. Un portail fait par et pour ceux qui aiment cette ville,
        en espagnol, anglais et français.
      </p>
      <div class="home-intro__pillars">
        <a href={`${base}/fr/fiestas`} class="home-intro__pillar">
          <span>Fêtes</span>
        </a>
        <a href={`${base}/fr/turismo`} class="home-intro__pillar">
          <span>Tourisme</span>
        </a>
        <a href={`${base}/fr/gastronomia`} class="home-intro__pillar">
          <span>Gastronomie</span>
        </a>
        <a href={`${base}/fr/cultura`} class="home-intro__pillar">
          <span>Culture</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <div class="container section">
    <div class="home-articles__header">
      <h2 class="home-articles__title">À la une</h2>
      <a href={`${base}/fr/turismo`} class="home-articles__all">Voir tous les articles →</a>
    </div>
    {featured.length > 0
      ? <ArticleGrid articles={featured} lang={lang} />
      : <p class="empty-msg">{t(lang, 'category.no_articles')}</p>
    }
  </div>
</BaseLayout>

<script>
  const words = ['vivante', 'joyeuse', 'salée', 'lumineuse', 'éternelle', 'magique', 'infinie'];
  const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#3b82f6', '#6366f1', '#a855f7'];
  const anims = ['anim-0', 'anim-1', 'anim-2', 'anim-3', 'anim-4', 'anim-5', 'anim-6'];
  let idx = 0;
  const el = document.getElementById('hero-word');
  if (el) {
    setInterval(() => {
      idx = (idx + 1) % words.length;
      el.textContent = words[idx];
      el.style.color = colors[idx];
      el.className = `word-slider-item ${anims[idx]}`;
    }, 2000);
  }
</script>
