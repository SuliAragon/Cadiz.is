---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AiBadge from '../../../components/ui/AiBadge.astro';
import Badge from '../../../components/ui/Badge.astro';
import { t, CATEGORIES } from '../../../i18n/index';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', (entry) => entry.id.startsWith('es/'));
  return articles.map((article) => ({
    params: { slug: article.data.articleSlug },
    props: { article },
  }));
}

const lang = 'es';
const { article } = Astro.props;
const { Content } = await article.render();
const { data } = article;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categoryName = data.category && data.category in CATEGORIES
  ? CATEGORIES[data.category as keyof typeof CATEGORIES][lang]
  : data.category;

const publishedDate = new Date(data.publishedAt).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric',
});

// Load authors
const authorsData = await import('../../../data/authors.json');
const author = authorsData.authors.find((a) => a.id === data.author);
---

<BaseLayout lang={lang} title={data.title} description={data.excerpt} image={data.image}>
  <article class="article-detail container">
    <header class="article-detail__header">
      <div class="article-detail__meta">
        {data.category && <Badge category={data.category} label={categoryName} />}
      </div>
      <h1 class="article-detail__title">{data.title}</h1>
      <p class="article-detail__excerpt">{data.excerpt}</p>
      {publishedDate && <p class="article-detail__date">{publishedDate}</p>}
    </header>

    {data.image && (
      <figure class="article-detail__figure">
        <img src={`${base}${data.image}`} alt={data.imageAlt ?? data.title} loading="lazy" />
        {data.imageCredit && (
          <figcaption class="article-detail__credit">{data.imageCredit}</figcaption>
        )}
      </figure>
    )}

    <div class="article-detail__content">
      <Content />
    </div>

    {author && (
      <div class="author-byline">
        <div class="author-byline__avatar">
          {author.avatar
            ? <img src={author.avatar} alt={author.name} loading="lazy" />
            : <span>{author.name.charAt(0)}</span>
          }
        </div>
        <div class="author-byline__body">
          <p class="author-byline__label">{t(lang, 'article.written_by')}</p>
          <p class="author-byline__name">{author.name}</p>
          <p class="author-byline__bio">{author.bio[lang] ?? author.bio.es}</p>
        </div>
      </div>
    )}
  </article>
</BaseLayout>
