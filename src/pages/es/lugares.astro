---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaceCard from '../../components/places/PlaceCard.astro';
import ArticleGrid from '../../components/articles/ArticleGrid.astro';
import { t } from '../../i18n/index';
import { getCollection } from 'astro:content';
import placesData from '../../data/places.json';

const lang = 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = await getCollection('articles', (entry) =>
  entry.id.startsWith('es/') && entry.data.category === 'lugares'
);
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const articles = sorted.slice(0, 9);
const hasMore = sorted.length > 9;
---

<BaseLayout lang={lang} title={t(lang, 'nav.places')}>
  <section class="container section">
    <h1 class="page-title">{t(lang, 'nav.places')}</h1>
    <p class="page-lead">{t(lang, 'places.desc')}</p>
    <div class="articles-grid">
      {placesData.places.map((place) => (
        <PlaceCard place={place} lang={lang} />
      ))}
    </div>
    {articles.length > 0 && (
      <div style="margin-top: 3rem;">
        <h2 class="section-title" style="margin-bottom: 1.5rem;">Artículos sobre lugares</h2>
        <ArticleGrid articles={articles} lang={lang} />
        {hasMore && (
          <div style="text-align:center; margin-top: 2rem;">
            <a href={`${base}/es/articulos`} class="home-articles__all">Ver todos los artículos →</a>
          </div>
        )}
      </div>
    )}
  </section>
</BaseLayout>
