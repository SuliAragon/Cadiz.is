---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleGrid from '../../components/articles/ArticleGrid.astro';
import { t } from '../../i18n/index';
import { getCollection } from 'astro:content';

const lang = 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = await getCollection('articles', (entry) => entry.id.startsWith('es/'));
const sorted = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featured = sorted.slice(0, 6);

const heroWords = t(lang, 'home.hero_words') as unknown as string[];
---

<BaseLayout lang={lang} title={t(lang, 'meta.site_name')} description={t(lang, 'meta.site_description')}>
  <!-- HERO -->
  <section class="home-hero">
    <h1 class="home-hero__title" id="hero-title">
      Cádiz<span>.is</span>{' '}
      <span class="word-slider-container">
        <span class="word-slider-item anim-0" id="hero-word" style="color: #ef4444">
          {Array.isArray(heroWords) ? heroWords[0] : 'viva'}
        </span>
      </span>
    </h1>
    <a class="home-hero__quiz-btn" href={`${base}/${lang}/quiz`}>
      🐟 <span>{t(lang, 'home.quiz')}</span> {t(lang, 'home.quiz_action')}
    </a>
    <div class="home-hero__subtitle">{t(lang, 'home.subtitle')}</div>
    <div class="home-hero__desc">{t(lang, 'home.desc')}</div>
  </section>

  <!-- INTRO -->
  <section class="home-intro">
    <div class="home-intro__inner">
      <p class="home-intro__label">¿Qué es cadiz.is?</p>
      <p class="home-intro__text">
        Cádiz es la ciudad más antigua de Occidente y una de las más vivas del planeta.
        <em>cadiz.is</em> nació para contarla sin filtros: sus fiestas, su gastronomía,
        sus playas, su historia y su alma. Un portal hecho por y para quienes aman esta ciudad,
        en español, inglés y francés.
      </p>
      <div class="home-intro__pillars">
        <a href={`${base}/es/fiestas`} class="home-intro__pillar">
          <span>Fiestas</span>
        </a>
        <a href={`${base}/es/turismo`} class="home-intro__pillar">
          <span>Turismo</span>
        </a>
        <a href={`${base}/es/gastronomia`} class="home-intro__pillar">
          <span>Gastronomía</span>
        </a>
        <a href={`${base}/es/cultura`} class="home-intro__pillar">
          <span>Cultura</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <div class="container section">
    <div class="home-articles__header">
      <h2 class="home-articles__title">Lo último</h2>
      <a href={`${base}/es/turismo`} class="home-articles__all">Ver todos los artículos →</a>
    </div>
    {featured.length > 0
      ? <ArticleGrid articles={featured} lang={lang} />
      : <p class="empty-msg">{t(lang, 'category.no_articles')}</p>
    }
  </div>
</BaseLayout>

<script>
  const words = ['viva', 'alegre', 'salada', 'luminosa', 'eterna', 'mágica', 'infinita'];
  const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#3b82f6', '#6366f1', '#a855f7'];
  const anims = ['anim-0', 'anim-1', 'anim-2', 'anim-3', 'anim-4', 'anim-5', 'anim-6'];
  let idx = 0;
  const el = document.getElementById('hero-word');
  if (el) {
    setInterval(() => {
      idx = (idx + 1) % words.length;
      el.textContent = words[idx];
      el.style.color = colors[idx];
      el.className = `word-slider-item ${anims[idx]}`;
    }, 2000);
  }
</script>
